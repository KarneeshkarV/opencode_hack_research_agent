{
  "name": "@research-agent/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "research-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.jsx",
    "build": "esbuild src/index.jsx --bundle --platform=node --format=esm --packages=external --banner:js='#!/usr/bin/env node' --outfile=dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "meow": "^14.1.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "7.37.5",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6"
  },
  "engines": {
    "node": ">=20"
  }
}
